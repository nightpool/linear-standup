{
  "manifest_version": 3,
  "name": "Linear Standup",
  "version": "1.0",
  "description": "Randomize standup order, track time per person, and navigate with spacebar",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Linear Standup"
  },
  "content_scripts": [
    {
      "matches": ["https://linear.app/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
